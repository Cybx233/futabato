{
  "manifest_version": 3,
  "name": "在公众号看漫画",
  "version": "0.1.0",
  "description": "双页阅读，纯离线",
  "host_permissions": ["https://mp.weixin.qq.com/*"],
  "action": {
    "default_title": "切换漫画阅读模式",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://mp.weixin.qq.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
